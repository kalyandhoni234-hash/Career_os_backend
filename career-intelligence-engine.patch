+"""Achievement definitions.
+
+Each entry is a dict with:
+  code:        stable unique id, never change once shipped (used for the DB unique constraint)
+  title:       display name
+  description: display description
+  category:    resume | projects | applications | interview | integrations | roadmap | skills
+  icon:        icon slug for the frontend
+  check(ctx):  pure function of the context dict built in service.build_context(),
+               returns True if the achievement should be awarded
+
+Keeping `check` pure and side-effect free means these can be unit tested directly
+without touching the database.
+"""
+
+ACHIEVEMENT_DEFINITIONS = [
+    {
+        "code": "first_resume",
+        "title": "First Resume",
+        "description": "Created your first resume.",
+        "category": "resume",
+        "icon": "file-text",
+        "check": lambda ctx: ctx["has_resume"],
+    },
+    {
+        "code": "first_project",
+        "title": "First Project",
+        "description": "Added your first project (manually or via GitHub sync).",
+        "category": "projects",
+        "icon": "code",
+        "check": lambda ctx: ctx["project_count"] >= 1,
+    },
+    {
+        "code": "project_builder",
+        "title": "Project Builder",
+        "description": "Tracked 5 or more projects across your profile.",
+        "category": "projects",
+        "icon": "layers",
+        "check": lambda ctx: ctx["project_count"] >= 5,
+    },
+    {
+        "code": "github_connected",
+        "title": "GitHub Explorer",
+        "description": "Connected your GitHub account.",
+        "category": "integrations",
+        "icon": "github",
+        "check": lambda ctx: ctx["github_connected"],
+    },
+    {
+        "code": "linkedin_connected",
+        "title": "Networking Explorer",
+        "description": "Connected your LinkedIn account.",
+        "category": "integrations",
+        "icon": "linkedin",
+        "check": lambda ctx: ctx["linkedin_connected"],
+    },
+    {
+        "code": "first_application",
+        "title": "First Application",
+        "description": "Submitted your first job application.",
+        "category": "applications",
+        "icon": "send",
+        "check": lambda ctx: ctx["application_count"] >= 1,
+    },
+    {
+        "code": "ten_applications",
+        "title": "Job Hunter",
+        "description": "Submitted 10 job applications.",
+        "category": "applications",
+        "icon": "briefcase",
+        "check": lambda ctx: ctx["application_count"] >= 10,
+    },
+    {
+        "code": "hundred_applications",
+        "title": "100 Applications",
+        "description": "Submitted 100 job applications. Persistence pays off.",
+        "category": "applications",
+        "icon": "target",
+        "check": lambda ctx: ctx["application_count"] >= 100,
+    },
+    {
+        "code": "first_interview",
+        "title": "Interview Ready",
+        "description": "Landed your first interview.",
+        "category": "interview",
+        "icon": "message-circle",
+        "check": lambda ctx: ctx["interview_count"] >= 1,
+    },
+    {
+        "code": "first_offer",
+        "title": "First Offer",
+        "description": "Received your first job offer.",
+        "category": "interview",
+        "icon": "award",
+        "check": lambda ctx: ctx["offer_count"] >= 1,
+    },
+    {
+        "code": "roadmap_completed",
+        "title": "Roadmap Completed",
+        "description": "Completed every step in a learning roadmap.",
+        "category": "roadmap",
+        "icon": "map",
+        "check": lambda ctx: ctx["completed_roadmap_count"] >= 1,
+    },
+    {
+        "code": "skill_collector",
+        "title": "Skill Collector",
+        "description": "Have 10 or more skills tracked across resume, GitHub, and LinkedIn.",
+        "category": "skills",
+        "icon": "star",
+        "check": lambda ctx: ctx["skill_count"] >= 10,
+    },
+    {
+        "code": "profile_complete",
+        "title": "Profile Complete",
+        "description": "Reached 80% profile completion.",
+        "category": "resume",
+        "icon": "check-circle",
+        "check": lambda ctx: ctx["completion_score"] >= 80,
+    },
+]
+
+
+def evaluate(ctx: dict) -> list[dict]:
+    """Return the list of achievement definitions whose check passes for ctx."""
+    earned = []
+    for definition in ACHIEVEMENT_DEFINITIONS:
+        try:
+            if definition["check"](ctx):
+                earned.append(definition)
+        except Exception:
+            # A malformed/missing context key should never crash the caller -
+            # just skip that achievement this round.
+            continue
+    return earned
