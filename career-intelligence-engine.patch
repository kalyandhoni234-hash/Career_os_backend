@@ -0,0 +1,26 @@
+from datetime import datetime, timezone
+from app.extensions import db
+
+
+class Achievement(db.Model):
+    """A badge awarded to a user once, when a condition in
+    app/achievements/definitions.py is first satisfied."""
+
+    __tablename__ = "achievements"
+
+    id = db.Column(db.Integer, primary_key=True)
+    user_id = db.Column(db.Integer, db.ForeignKey("users.id"), nullable=False)
+
+    code = db.Column(db.String(100), nullable=False)
+    title = db.Column(db.String(255), nullable=False)
+    description = db.Column(db.Text, nullable=True)
+    category = db.Column(db.String(50), default="general")
+    icon = db.Column(db.String(50), default="trophy")
+
+    awarded_at = db.Column(db.DateTime, default=lambda: datetime.now(timezone.utc))
+
+    user = db.relationship("User", backref=db.backref("achievements", lazy="dynamic"))
+
+    __table_args__ = (
+        db.UniqueConstraint("user_id", "code", name="uq_achievement_user_code"),
+    )
