+
+
+@pytest.fixture
+def app():
+    app = create_app()
+    app.config.update(
+        {
+            "TESTING": True,
+            "SQLALCHEMY_DATABASE_URI": "sqlite:///:memory:",
+            "SQLALCHEMY_ENGINE_OPTIONS": {
+                "poolclass": StaticPool,
+                "connect_args": {"check_same_thread": False},
+            },
+            "WTF_CSRF_ENABLED": False,
+        }
+    )
+    with app.app_context():
+        db.create_all()
+        yield app
+        db.session.remove()
+        db.drop_all()
+
+
+@pytest.fixture
+def client(app):
+    return app.test_client()
+
+
+@pytest.fixture
+def logged_in_client(client):
+    client.post(
+        "/api/auth/signup",
+        json={"email": "achievementuser@example.com", "password": "securepass123"},
+    )
+    client.post(
+        "/api/auth/login",
+        json={"email": "achievementuser@example.com", "password": "securepass123"},
+    )
+    return client
+
+
+def test_definitions_are_pure_and_evaluate_correctly():
+    """Achievement checks are pure functions of a context dict - no DB needed."""
+    from app.achievements.definitions import evaluate
+
+    ctx = {
+        "has_resume": True,
+        "project_count": 5,
+        "skill_count": 12,
+        "completion_score": 85,
+        "github_connected": True,
+        "linkedin_connected": False,
+        "application_count": 10,
+        "interview_count": 1,
+        "offer_count": 0,
+        "completed_roadmap_count": 0,
+    }
+    earned_codes = {d["code"] for d in evaluate(ctx)}
+    assert "first_resume" in earned_codes
+    assert "first_project" in earned_codes
+    assert "project_builder" in earned_codes
+    assert "github_connected" in earned_codes
+    assert "linkedin_connected" not in earned_codes
+    assert "ten_applications" in earned_codes
+    assert "hundred_applications" not in earned_codes
+    assert "first_interview" in earned_codes
+    assert "first_offer" not in earned_codes
+    assert "skill_collector" in earned_codes
+    assert "profile_complete" in earned_codes
+
+
+def test_evaluate_and_award_persists_once(app):
+    """Awarding the same achievement twice should not create duplicate rows,
+    and newly_awarded should only report genuinely new ones."""
+    with app.app_context():
+        from app.auth.models import User
+        from app.achievements.service import evaluate_and_award, list_achievements
+        from app.achievements.models import Achievement
+        from app.jobs.models import Job
+
+        user = User(email="scoreachieve@example.com")
+        user.password_hash = "not-a-real-hash"
+        db.session.add(user)
+        db.session.commit()
+
+        job = Job(user_id=user.id, company="Acme", role="SOC Analyst", status="applied")
+        db.session.add(job)
+        db.session.commit()
+
+        first_pass = evaluate_and_award(user.id)
+        assert any(d["code"] == "first_application" for d in first_pass)
+
+        second_pass = evaluate_and_award(user.id)
+        assert second_pass == []  # nothing new the second time
+
+        awarded = Achievement.query.filter_by(user_id=user.id, code="first_application").all()
+        assert len(awarded) == 1  # unique constraint respected, no duplicates
+
+        listed = list_achievements(user.id)
+        assert any(a["code"] == "first_application" for a in listed)
+
+
+def test_achievements_endpoint_requires_login(client):
+    response = client.get("/api/achievements")
+    assert response.status_code in (401, 302)
+
+
+def test_achievements_endpoint_lists_catalog(logged_in_client):
+    response = logged_in_client.get("/api/achievements")
+    assert response.status_code == 200
+    data = response.get_json()
+    assert "earned" in data
+    assert "catalog" in data
+    assert len(data["catalog"]) == len(
+        __import__("app.achievements.definitions", fromlist=["ACHIEVEMENT_DEFINITIONS"]).ACHIEVEMENT_DEFINITIONS
+    )
+    assert all("unlocked" in item for item in data["catalog"])
+
+
+def test_resume_creation_awards_first_resume_achievement(logged_in_client, app):
+    """Creating a resume should trigger on_resume_changed -> achievement
+    evaluation -> first_resume being earned, end to end through the real
+    integration hook, not just the service function directly."""
+    response = logged_in_client.post(
+        "/api/resume",
+        json={"full_name": "Guru Sharan", "summary": "SOC Analyst in training"},
+    )
+    assert response.status_code in (200, 201)
+
+    achievements_response = logged_in_client.get("/api/achievements")
+    data = achievements_response.get_json()
+    earned_codes = {a["code"] for a in data["earned"]}
+    assert "first_resume" in earned_codes
