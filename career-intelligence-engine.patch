+from app import create_app
+from app.extensions import db
+
+
+@pytest.fixture
+def app():
+    app = create_app()
+    app.config.update(
+        {
+            "TESTING": True,
+            "SQLALCHEMY_DATABASE_URI": "sqlite:///:memory:",
+            "SQLALCHEMY_ENGINE_OPTIONS": {
+                "poolclass": StaticPool,
+                "connect_args": {"check_same_thread": False},
+            },
+            "WTF_CSRF_ENABLED": False,
+        }
+    )
+    with app.app_context():
+        db.create_all()
+        yield app
+        db.session.remove()
+        db.drop_all()
+
+
+def _create_user(app, email):
+    from app.auth.models import User
+
+    user = User(email=email)
+    user.password_hash = "not-a-real-hash"
+    db.session.add(user)
+    db.session.commit()
+    return user.id
+
+
+def test_roadmap_skips_nodes_for_already_known_skills(app):
+    """A user whose GitHub-synced skills already cover 'Python Fundamentals'
+    should get that backend roadmap node auto-completed instead of pending -
+    this is the doc's 'skip beginner Python if user already knows Python'
+    requirement."""
+    with app.app_context():
+        from app.intelligence.engine import sync_skills_from_source
+        from app.career.services.roadmap_service import generate_roadmap
+
+        user_id = _create_user(app, "roadmapuser1@example.com")
+
+        # User already knows Python (synced from GitHub), but not Flask/Docker/etc.
+        sync_skills_from_source(user_id, [{"name": "Python"}], "github")
+        db.session.commit()
+
+        roadmap = generate_roadmap(user_id, category="backend")
+
+        node_by_title = {n["title"]: n for n in roadmap["nodes"]}
+        assert node_by_title["Python Fundamentals"]["status"] == "completed"
+        assert node_by_title["Python Fundamentals"]["completed_at"] is not None
+        # Docker node requires a skill they don't have yet - stays pending
+        assert node_by_title["Docker & Containerization"]["status"] == "pending"
+        assert roadmap["completed_nodes"] >= 1
+        assert roadmap["progress"] > 0
+
+
+def test_roadmap_all_pending_when_no_known_skills(app):
+    """A brand-new user with no synced skills gets a fully pending roadmap,
+    preserving old behavior."""
+    with app.app_context():
+        from app.career.services.roadmap_service import generate_roadmap
+
+        user_id = _create_user(app, "roadmapuser2@example.com")
+
+        roadmap = generate_roadmap(user_id, category="backend")
+
+        assert roadmap["completed_nodes"] == 0
+        assert roadmap["progress"] == 0
+        assert all(n["status"] == "pending" for n in roadmap["nodes"])
