@@ -0,0 +1,114 @@
+import logging
+
+from app.extensions import db
+from app.achievements.definitions import evaluate
+from app.achievements.models import Achievement
+
+logger = logging.getLogger(__name__)
+
+
+def build_context(user_id: int) -> dict:
+    """Assemble the data achievement checks need, reusing the same canonical
+    sources as the coach and career score (get_unified_profile, Job, Roadmap,
+    Integration) so achievements never drift out of sync with what the rest
+    of Career OS considers true.
+    """
+    from app.intelligence.engine import get_unified_profile
+    from app.jobs.models import Job
+    from app.career.models import Roadmap
+    from app.integrations.models import Integration
+
+    profile = get_unified_profile(user_id)
+
+    jobs = Job.query.filter_by(user_id=user_id).all()
+    roadmaps = Roadmap.query.filter_by(user_id=user_id).all()
+    connected = {i.provider for i in Integration.query.filter_by(user_id=user_id).all()}
+
+    return {
+        "has_resume": bool(profile.get("basic", {}).get("full_name")) or bool(profile.get("basic", {}).get("summary")),
+        "project_count": len(profile.get("projects", [])),
+        "skill_count": len(profile.get("skills", [])),
+        "completion_score": profile.get("completion", {}).get("score", 0),
+        "github_connected": "github" in connected,
+        "linkedin_connected": "linkedin" in connected,
+        "application_count": len(jobs),
+        "interview_count": sum(1 for j in jobs if j.status in ("interview", "offer")),
+        "offer_count": sum(1 for j in jobs if j.status == "offer"),
+        "completed_roadmap_count": sum(1 for r in roadmaps if r.status == "completed"),
+    }
+
+
+def evaluate_and_award(user_id: int) -> list[dict]:
+    """Check all achievement definitions for user_id and persist any newly
+    earned ones. Returns the list of achievements newly awarded this call
+    (empty list if none, or if evaluation fails - this is a best-effort
+    enrichment, never a hard dependency for the caller).
+    """
+    try:
+        ctx = build_context(user_id)
+        earned_defs = evaluate(ctx)
+        existing_codes = {
+            a.code for a in Achievement.query.filter_by(user_id=user_id).all()
+        }
+
+        newly_awarded = []
+        for definition in earned_defs:
+            if definition["code"] in existing_codes:
+                continue
+            achievement = Achievement(
+                user_id=user_id,
+                code=definition["code"],
+                title=definition["title"],
+                description=definition["description"],
+                category=definition["category"],
+                icon=definition["icon"],
+            )
+            db.session.add(achievement)
+            newly_awarded.append(definition)
+
+        if newly_awarded:
+            db.session.commit()
+            for definition in newly_awarded:
+                _log_achievement_event(user_id, definition)
+        return newly_awarded
+    except Exception:
+        db.session.rollback()
+        logger.warning("Achievement evaluation failed for user %s", user_id, exc_info=True)
+        return []
+
+
+def _log_achievement_event(user_id: int, definition: dict) -> None:
+    """Best-effort: also surface a newly earned achievement on the main
+    timeline, reusing the existing dual-write log_event() from the
+    intelligence engine."""
+    try:
+        from app.intelligence.engine import log_event
+
+        log_event(
+            user_id,
+            "achievement",
+            f"Achievement unlocked: {definition['title']}",
+            definition["description"],
+            event_source="achievements",
+        )
+    except Exception:
+        logger.warning("Failed to log achievement event for user %s", user_id, exc_info=True)
+
+
+def list_achievements(user_id: int) -> list[dict]:
+    rows = (
+        Achievement.query.filter_by(user_id=user_id)
+        .order_by(Achievement.awarded_at.desc())
+        .all()
+    )
+    return [
+        {
+            "code": a.code,
+            "title": a.title,
+            "description": a.description,
+            "category": a.category,
+            "icon": a.icon,
+            "awarded_at": a.awarded_at.isoformat() if a.awarded_at else None,
+        }
+        for a in rows
+    ]
