+    app = create_app()
+    app.config.update(
+        {
+            "TESTING": True,
+            "SQLALCHEMY_DATABASE_URI": "sqlite:///:memory:",
+            "SQLALCHEMY_ENGINE_OPTIONS": {
+                "poolclass": StaticPool,
+                "connect_args": {"check_same_thread": False},
+            },
+            "WTF_CSRF_ENABLED": False,
+        }
+    )
+    with app.app_context():
+        db.create_all()
+        yield app
+        db.session.remove()
+        db.drop_all()
+
+
+def _create_user(app, email="memoryuser@example.com"):
+    from app.auth.models import User
+
+    user = User(email=email)
+    user.password_hash = "not-a-real-hash"
+    db.session.add(user)
+    db.session.commit()
+    return user.id
+
+
+def test_build_career_memory_includes_canonical_github_skills(app):
+    """Skills synced from GitHub (via the Career Intelligence Engine) must be
+    visible to the coach's memory context, not just resume/profile skills.
+    This is the fix for the coach previously being blind to synced data."""
+    with app.app_context():
+        from app.intelligence.engine import sync_skills_from_source, sync_projects_from_source
+        from app.career.services.career_memory_service import build_career_memory
+
+        user_id = _create_user(app)
+
+        sync_skills_from_source(
+            user_id, [{"name": "Docker", "experience_level": "intermediate"}], "github"
+        )
+        sync_projects_from_source(
+            user_id, [{"name": "cyberguru-ai", "primary_language": "Python", "url": "https://github.com/x/y"}], "github"
+        )
+        db.session.commit()
+
+        memory = build_career_memory(user_id)
+
+        assert "Docker" in memory["skills"]["all_skill_names"]
+        assert any(s["name"] == "Docker" for s in memory["skills"]["canonical_skills"])
+        assert any(p["name"] == "cyberguru-ai" for p in memory["projects"])
+        assert "completion" not in memory  # renamed to profile_completion
+        assert "score" in memory["profile_completion"]
+
+
+def test_build_career_memory_survives_engine_failure(app, monkeypatch):
+    """If the intelligence engine raises, the coach should still get a usable
+    (if less complete) memory object instead of a hard failure."""
+    with app.app_context():
+        import app.career.services.career_memory_service as svc
+
+        user_id = _create_user(app, email="memoryuser2@example.com")
+
+        def boom(_user_id):
+            raise RuntimeError("engine down")
+
+        monkeypatch.setattr(
+            "app.intelligence.engine.get_unified_profile", boom
+        )
+
+        memory = svc.build_career_memory(user_id)
+        assert memory["projects"] == []
+        assert memory["skills"]["canonical_skills"] == []
