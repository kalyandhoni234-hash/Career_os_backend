@@ -0,0 +1,55 @@
+from flask import Blueprint, jsonify
+from flask_login import login_required, current_user
+
+from app.achievements.service import evaluate_and_award, list_achievements
+from app.achievements.definitions import ACHIEVEMENT_DEFINITIONS
+
+achievements_bp = Blueprint("achievements", __name__)
+
+
+@achievements_bp.route("/ping")
+def ping():
+    return {"blueprint": "achievements", "status": "alive"}
+
+
+@achievements_bp.route("", methods=["GET"])
+@login_required
+def get_achievements():
+    """List all achievements the user has earned, plus the full catalog so
+    the frontend can render locked/unlocked state."""
+    earned = list_achievements(current_user.id)
+    earned_codes = {a["code"] for a in earned}
+    catalog = [
+        {
+            "code": d["code"],
+            "title": d["title"],
+            "description": d["description"],
+            "category": d["category"],
+            "icon": d["icon"],
+            "unlocked": d["code"] in earned_codes,
+        }
+        for d in ACHIEVEMENT_DEFINITIONS
+    ]
+    return jsonify({"earned": earned, "catalog": catalog}), 200
+
+
+@achievements_bp.route("/evaluate", methods=["POST"])
+@login_required
+def evaluate_now():
+    """Manually re-run achievement evaluation for the current user.
+
+    Achievements are normally awarded automatically via the existing
+    integration hooks (resume/application/roadmap/profile changes); this
+    endpoint exists for backfilling users who earned something before this
+    feature existed, or for the frontend to call right after an action it
+    knows might unlock something.
+    """
+    newly_awarded = evaluate_and_award(current_user.id)
+    return jsonify(
+        {
+            "newly_awarded": [
+                {"code": d["code"], "title": d["title"], "description": d["description"]}
+                for d in newly_awarded
+            ]
+        }
+    ), 200
